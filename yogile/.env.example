# ClickHouse
CLICKHOUSE_HOST="localhost"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD="secret"
CLICKHOUSE_DATABASE="yogile"

# Yogile API
YOGILE_BASE_URL="https://ru.yougile.com"
YOGILE_API_TOKEN=           # Bearer токен из настроек Yogile

# UUID стикеров (Settings → Stickers → скопировать ID)
YOGILE_STICKER_SP_FRONTEND=0caa3b6f-170c-4ece-bff5-eab37c699542 # UUID числового стикера "SP Frontend"
YOGILE_STICKER_SP_BACKEND=9a0a8a72-26df-4aeb-80cf-e6271bdb160e  # UUID числового стикера "SP Backend"
YOGILE_STICKER_PROJECT=06ea5708-ba40-429c-8a34-90048d73d9fe     # UUID стикера с состояниями "Проект"
YOGILE_STICKER_SPRINT=3ed17d59-3c33-4e6d-9db3-45b56f4f6b0a     # UUID стикера спринта "Sprint"

# Спринт
YOGILE_SPRINT_START=2025-01-06   # Дата начала первого спринта (YYYY-MM-DD)
YOGILE_SPRINT_LENGTH_DAYS=14     # Длина одного спринта в днях

# Фильтрация
YOGILE_CARDS_FROM=2025-01-06     # Карточки, созданные раньше этой даты, не сохраняются
# Обязательно. Проекты через запятую: "Проект А,Проект Б"
YOGILE_PROJECTS="7eed460a-ccdb-4095-970d-318953e834d6"
